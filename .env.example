# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# CORS — set to your frontend origin in production (e.g. https://app.lamuri.co.ke)
CORS_ORIGIN=*

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Full connection string; Railway injects this automatically when a Postgres
# service is linked. For local development use a local or Docker Postgres.
DATABASE_URL=postgresql://postgres:password@localhost:5432/lamuricarhire

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used by BullMQ for job queues (payouts, SMS dispatch, automation rules).
# Railway injects this automatically when a Redis service is linked.
REDIS_URL=redis://localhost:6379

# ─── M-Pesa (Daraja API) ─────────────────────────────────────────────────────
# See integrations/05-mpesa-integration-spec.md for full setup instructions.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# ─── Africa's Talking (SMS) ───────────────────────────────────────────────────
# See integrations/06-africastalking-sms-spec.md for full setup instructions.
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=LAMURI
